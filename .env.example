# =============================================================================
# Conductor Orchestrator — Consolidated Environment Variables
# =============================================================================
# Copy to .env and fill in values. All agents share these credentials.

# --- Core (required by ALL agents) ---
LINEAR_API_KEY=lin_api_xxxx
GH_TOKEN=github_pat_xxxx

# --- Claude / OpenClaw (required by NightShift, PR Resolver, Pathfinder) ---
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxx

# --- Telegram (Conductor escalations + PR Resolver notifications) ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Slack (PR Review Bot notifications) ---
SLACK_BOT_TOKEN=xoxb-your-token

# --- GitHub Webhook (PR Review Bot) ---
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_BOT_USERNAME=your-bot-username

# --- NightShift specific ---
GITHUB_ORG=ruh-ai
TARGET_BRANCH=dev
REPOS_DIR=./repos
LOGS_DIR=./logs
POLL_INTERVAL_MINUTES=60
MAX_CONCURRENT_TICKETS=2
MAX_CONCURRENT_REPOS=3
SENTINEL_SKILLS_PATH=~/.openclaw/workspace/sentinel-guardian/skills
SSH_KEY_PATH=~/.ssh/id_ed25519

# --- PR Resolver specific ---
BOT_GITHUB_USER=AdityaRuh
LINEAR_ASSIGNEE_EMAIL=your-email@example.com
LINEAR_DEFAULT_TEAM=RP
REPOS_BASE_DIR=~/repos
OPENCLAW_TIMEOUT=600

# --- Conductor specific ---
CONDUCTOR_HEARTBEAT_INTERVAL=15m
CONDUCTOR_MAX_REVIEW_LOOP=5
CONDUCTOR_MAX_CI_REPAIRS=3
CONDUCTOR_DEFAULT_BUDGET=100000
